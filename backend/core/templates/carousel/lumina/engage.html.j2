{% extends "_base.html.j2" %}

{% block extra_styles %}
.engage-canvas {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 72px;
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
}
.eng-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.18);
    pointer-events: none;
}
.engage-inner {
    position: absolute;
    top: 50%; left: 80px; right: 80px;
    transform: translateY(-50%);
    display: flex; flex-direction: column;
    align-items: center;
    gap: 28px;
    text-align: center;
}
.engage-eyebrow {
    font-size: 14px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(255,255,255,0.72);
    background: rgba(255,255,255,0.16);
    padding: 6px 20px; border-radius: 999px;
}
.engage-title {
    font-family: 'Syne', sans-serif;
    font-size: 46px; font-weight: 700;
    line-height: 1.18;
    color: #fff;
    max-width: 820px;
}
.engage-body {
    font-size: 22px; font-weight: 400;
    line-height: 1.6;
    color: rgba(255,255,255,0.84);
    max-width: 720px;
}
.engage-pill {
    background: rgba(255,255,255,0.22);
    border: 1px solid rgba(255,255,255,0.35);
    border-radius: 999px;
    padding: 12px 36px;
    font-size: 18px; font-weight: 600;
    color: #fff;
    letter-spacing: 0.02em;
}
{% endblock %}

{% block content %}
<div class="engage-canvas">
    <div style="position:absolute;inset:0;pointer-events:none;">
        <div class="eng-ring" style="width:560px;height:560px;top:-200px;right:-180px;"></div>
        <div class="eng-ring" style="width:360px;height:360px;bottom:-140px;left:-100px;"></div>
        <div class="eng-ring" style="width:200px;height:200px;bottom:80px;right:60px;opacity:0.6;"></div>
    </div>
    <div class="engage-inner">
        <div class="engage-eyebrow">Follow for more insights</div>
        <div class="engage-title">{{ slide.title }}</div>
        {% if slide.body %}
        <div class="engage-body">{{ slide.body }}</div>
        {% endif %}
        <div class="engage-pill">Hit Follow — it's worth it</div>
    </div>
</div>
{% endblock %}
