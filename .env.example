# ============================================
# LLM Provider Selection
# ============================================
# Options: "claude", "openai", "gemini"
LLM_PROVIDER=claude

# ============================================
# Claude Settings (via HAI Proxy)
# ============================================
# Required when LLM_PROVIDER=claude
HAI_PROXY_URL=http://localhost:6655/anthropic
HAI_PROXY_API_KEY=your-hai-proxy-api-key-here

# ============================================
# OpenAI Settings
# ============================================
# Required when LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1  # Optional, for custom endpoints

# ============================================
# Google Gemini Settings
# ============================================
# Required when LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# General LLM Settings
# ============================================
# Model name (provider-specific format)
# Claude: anthropic--claude-4.5-sonnet, anthropic--claude-haiku-4.5
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Gemini: gemini-pro, gemini-pro-vision
LLM_MODEL=anthropic--claude-4.5-sonnet

# LLM parameters
LLM_TIMEOUT=300.0
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=1.0

# ============================================
# Logging Settings
# ============================================
LOG_LEVEL=INFO
ENVIRONMENT=development
